APP_ENV=development
HTTP_ADDR=:8080

DATABASE_URL=postgres://pqmedia:pqmedia@localhost:5432/pqmedia?sslmode=disable

# 32+ chars random — generate via: openssl rand -base64 48
JWT_SECRET=replace-me-with-long-random-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=720h

ALLOWED_ORIGINS=http://localhost:5173

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=pqmedia
MINIO_SECRET_KEY=pqmediasecret
MINIO_BUCKET=pqmedia
MINIO_REGION=us-east-1
MINIO_USE_SSL=false
MINIO_PUBLIC_BASE_URL=http://localhost:9000/pqmedia

# Generated by `go run ./cmd/generatevapid` in Phase 6
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
WEB_PUSH_VAPID_SUBJECT=mailto:admin@pqmedia.local

APP_ENV=production
HTTP_ADDR=:8080
DATABASE_URL=postgres://username:password@db-host:5432/pqmedia?sslmode=disable
JWT_SECRET=change-me
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=720h
ALLOWED_ORIGINS=https://app.example.com

MINIO_ENDPOINT=minio.example.com
MINIO_ACCESS_KEY=access-key
MINIO_SECRET_KEY=secret-key
MINIO_BUCKET=pqmedia
MINIO_REGION=us-east-1
MINIO_USE_SSL=true
MINIO_PUBLIC_BASE_URL=https://minio.example.com/pqmedia

GOOGLE_DRIVE_ENABLE_VIDEO_SYNC=false
GOOGLE_DRIVE_OAUTH_CLIENT_ID=
GOOGLE_DRIVE_OAUTH_CLIENT_SECRET=
GOOGLE_DRIVE_OAUTH_REDIRECT_URL=https://api.example.com/oauth/google/drive/callback
GOOGLE_DRIVE_OAUTH_POST_CONNECT_URL=https://app.example.com/settings/drive
GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON=
GOOGLE_DRIVE_SERVICE_ACCOUNT_FILE=./pq-media.json
GOOGLE_DRIVE_ROOT_FOLDER_ID=
GOOGLE_DRIVE_SHARED_DRIVE_ID=
GOOGLE_DRIVE_UPLOAD_TIMEOUT=15m
GOOGLE_DRIVE_SYNC_POLL_INTERVAL=15s
GOOGLE_DRIVE_SYNC_BATCH_SIZE=4
GOOGLE_DRIVE_RETRY_BASE_DELAY=1m
GOOGLE_DRIVE_RETRY_MAX_DELAY=1h

WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
WEB_PUSH_VAPID_SUBJECT=mailto:admin@example.com
